{
  "expo": {
    "name": "StyleScan",
    "slug": "stylescan-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "stylescan-app",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "StyleScan needs camera access to scan your face and recommend hairstyles.",
        "NSPhotoLibraryUsageDescription": "StyleScan needs photo library access to select a photo for your style scan."
      }
    },
    "android": {
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png",
      "meta": {
        "viewport": "width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no"
      }
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://style-scan-app.vercel.app"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-camera",
      [
        "expo-image-picker",
        {
          "photosPermission": "StyleScan needs photo access for your scan.",
          "cameraPermission": "StyleScan needs camera access to scan your face."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
